#include <stdio.h>
#include <string.h>
#include "game.h"

void initGame(GameState *gs)
{
    memset(gs, 0, sizeof(GameState));
    gs->currentPlayer = 'A';
    gs->totalBoxes    = ROWS * COLS;
    gs->claimedBoxes  = 0;
    gs->scoreA        = 0;
    gs->scoreB        = 0;
}

int applyMove(GameState *gs, int r1, int c1, int r2, int c2)
{
    if (r1 > r2 || (r1 == r2 && c1 > c2)) {
        int tmp;
        tmp = r1; r1 = r2; r2 = tmp;
        tmp = c1; c1 = c2; c2 = tmp;
    }

    if (r1 == r2 && c2 == c1 + 1) {
        int boxRow = r1;
        int boxCol = c1;
        int drawn = 0;

        if (boxRow < ROWS) {
            if (!gs->edges.top[boxRow][boxCol]) {
                gs->edges.top[boxRow][boxCol] = 1;
                drawn = 1;
            }
        }
        if (boxRow > 0) {
            if (!gs->edges.bottom[boxRow-1][boxCol]) {
                gs->edges.bottom[boxRow-1][boxCol] = 1;
                drawn = 1;
            }
        }
        return drawn;
    }

    if (c1 == c2 && r2 == r1 + 1) {
        int boxRow = r1;
        int boxCol = c1;
        int drawn = 0;

        if (boxCol < COLS) {
            if (!gs->edges.left[boxRow][boxCol]) {
                gs->edges.left[boxRow][boxCol] = 1;
                drawn = 1;
            }
        }
        if (boxCol > 0) {
            if (!gs->edges.right[boxRow][boxCol-1]) {
                gs->edges.right[boxRow][boxCol-1] = 1;
                drawn = 1;
            }
        }
        return drawn;
    }

    return 0;
}

int checkBoxes(GameState *gs, char player)
{
    int claimed = 0;
    int r, c;

    for (r = 0; r < ROWS; r++) {
        for (c = 0; c < COLS; c++) {
            if (gs->board.owner[r][c] == 0 &&
                gs->edges.top   [r][c] &&
                gs->edges.bottom[r][c] &&
                gs->edges.left  [r][c] &&
                gs->edges.right [r][c])
            {
                gs->board.owner[r][c] = player;
                gs->claimedBoxes++;
                claimed++;
                if (player == 'A') gs->scoreA++;
                else               gs->scoreB++;
            }
        }
    }
    return claimed;
}

int isGameOver(const GameState *gs)
{
    return gs->claimedBoxes == gs->totalBoxes;
}

char getWinner(const GameState *gs)
{
    if (gs->scoreA > gs->scoreB) return 'A';
    if (gs->scoreB > gs->scoreA) return 'B';
    return 'T';
}
